# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=oArP4WehPe3qjqvCwHNo
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# -----------------------------------------------------------------------------
