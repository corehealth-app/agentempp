{
  "name": "agentempp",
  "version": "0.0.1",
  "private": true,
  "description": "Agente MPP - Coach nutricional via WhatsApp (CoreHealth)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > packages/db/src/generated/database.ts",
    "db:diff": "supabase db diff",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset --linked",
    "db:lint": "supabase db lint --linked",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@types/node": "^22.10.5",
    "supabase": "^2.95.4",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  }
}
